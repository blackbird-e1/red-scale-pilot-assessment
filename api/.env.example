# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# PostgreSQL
# When running via Docker Compose, use the service name "postgres" as the host.
# The user/db must match POSTGRES_USER/POSTGRES_DB in docker-compose.yml.
DATABASE_URL=postgresql://f1_user:password@postgres:5433/f1
POSTGRES_PASSWORD=password
DATABASE_QUERY_TIMEOUT=5

# Redis
REDIS_URL=redis://redis:6379/0

# pgvector RAG
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
RATE_LIMIT_PER_MINUTE=20

# Environment
ENV=development
